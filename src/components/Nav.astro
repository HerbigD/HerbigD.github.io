---
const pathname = Astro.url.pathname;

const links = [
  { href: '/projects', label: 'Things I built' },
  { href: '/tech-blog', label: 'Notes' },
  { href: '/musings', label: 'Musings' },
  { href: '/collection', label: 'Collection' },
  { href: '/life', label: 'Days' },
];
---

<nav>
  <div class="container">
    <a href="/" class="nav-logo">D</a>
    <ul class="nav-links">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class={pathname.startsWith(link.href) ? 'active' : ''}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
