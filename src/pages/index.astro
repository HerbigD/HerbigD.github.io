---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const sections = [
  { href: '/projects', en: 'Things I built', zh: 'Experiments, builds, and ideas' },
  { href: '/tech-blog', en: 'Notes', zh: 'Things I’m learning and trying to understand' },
  { href: '/musings', en: 'Musings', zh: 'Half-formed thoughts and passing questions' },
  { href: '/collection', en: 'Collections', zh: 'Books, films, and things that stayed with me' },
  { href: '/life', en: 'Days', zh: 'Tennis,Gym,Food' },
];
---

<BaseLayout title="Home" description="头大的D 的个人网站">
  <div class="home-intro">
    <h1>头大的 D</h1>
    <p class="subtitle">INFP &nbsp;/&nbsp; lifelong learner &nbsp;/&nbsp; explorer &nbsp;/&nbsp; slow thinker</p>

    <div class="bio">
      <p>
      
      </p>
      <p>
       
      </p>
    </div>

    <div class="home-nav-grid">
      {sections.map(s => (
        <a href={s.href} class="home-nav-item">
          <span class="en">{s.en}</span>
          <span class="zh">{s.zh}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
