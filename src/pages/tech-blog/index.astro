---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostListItem from '../../components/PostListItem.astro';

const posts = (await getCollection('tech-blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="技术Blog" description="技术笔记与学习记录">
  <div class="page-header">
    <h1>技术 Blog</h1>
    <p>学习新技术、新知识时的记录</p>
  </div>

  {posts.length === 0 ? (
    <p style="color: var(--color-text-muted);">还没有文章，敬请期待。</p>
  ) : (
    <ul class="post-list">
      {posts.map(p => (
        <PostListItem
          title={p.data.title}
          date={p.data.date}
          slug={p.slug}
          section="tech-blog"
          description={p.data.description}
        />
      ))}
    </ul>
  )}
</BaseLayout>
